@app.post("/api/miniapp/sync-telegram-user")
async def api_miniapp_sync_user(request: Request):
    body = await request.json()
    tg_id = body.get("telegram_id", "")
    if not tg_id:
        return JSONResponse(content={"ok": False}, status_code=400)
    now = datetime.now(timezone.utc).isoformat()
    full_name = f"{body.get('first_name', '')} {body.get('last_name', '')}".strip() or "Telegram User"
    await db.miniapp_users.update_one(
        {"telegram_id": tg_id},
        {"$set": {"name": full_name, "username": body.get("username", ""), "last_sync": now},
         "$setOnInsert": {"telegram_id": tg_id, "plan_status": "free", "created_at": now}},
        upsert=True)
    return JSONResponse(content={"ok": True})

