    logger.info("═══════════════════════════════════════")


async def _push_intelligence_loop():
    """Push triggers every 3 minutes — syncs signals to mobile + miniapp."""
    await asyncio.sleep(30)
    while True:
        try:
            from services.push_triggers import run_all_triggers_all_users
            result = run_all_triggers_all_users()
            total = result.get('total_notifications', 0)
            if total > 0:
                logger.info(f"[Push] {total} notifications for {result.get('users_checked', 0)} users")
        except Exception as e:
            logger.debug(f"[Push] {e}")
        await asyncio.sleep(180)


async def _engine_snapshot_loop():
    """Full engine snapshots every 90s."""
    await asyncio.sleep(10)
    try:
        from engine_integration.engine_snapshot_service import ensure_indexes, build_engine_snapshot
        ensure_indexes()
    except: return
    while True:
        try:
            build_engine_snapshot()
        except: pass
        await asyncio.sleep(90)


async def _engine_micro_snapshot_loop():
    """Micro snapshots every 3 minutes."""
    await asyncio.sleep(20)
    try:
        from engine_integration.engine_snapshot_service import build_micro_snapshot
    except: return
    while True:
        try:
            build_micro_snapshot()
        except: pass
        await asyncio.sleep(180)


async def _fractal_forecast_scheduler():
    """Fractal forecast pipelines."""
    await asyncio.sleep(30)
    try:
        from fractal_forecast.pipeline import init_fractal_forecasts, run_all_pipelines
        init_fractal_forecasts()
        results = run_all_pipelines()
        logger.info(f"[Fractal] Startup: {results}")
    except Exception as e:
        logger.warning(f"[Fractal] Startup error: {e}")
    while True:
        now = datetime.now(timezone.utc)
        tomorrow = now.replace(hour=0, minute=15, second=0, microsecond=0)
        if tomorrow <= now:
            tomorrow += timedelta(days=1)
        await asyncio.sleep((tomorrow - now).total_seconds())
        try:
            from fractal_forecast.pipeline import run_all_pipelines
            run_all_pipelines()
        except: pass


async def _forecast_scheduler():
    """Forecast jobs every 6 hours."""
    await asyncio.sleep(5)
    try:
        from forecast.jobs import get_fractal_jobs
        from forecast.repo import ensure_indexes
        ensure_indexes()
        jobs = get_fractal_jobs()
        for job in jobs:
            if job.run_on_startup:
                try:
                    job.handler()
                except: pass
    except: return
    while True:
        await asyncio.sleep(6 * 3600)
        try:
            from forecast.jobs import get_fractal_jobs
            for job in get_fractal_jobs():
                try:
                    job.handler()
                except: pass
        except: pass


