    except Exception as e:
        logger.warning(f"[✗] Fractal module: {e}")

    # Knowledge Graph
    try:
        from knowledge_graph.api.routes import init_graph_services
        init_graph_services(db)
        logger.info("[✓] Knowledge Graph services initialized")
    except: pass

    # Prediction Market Watcher
    try:
        from prediction.monitoring.market_watcher import start_watcher
        start_watcher()
        logger.info("[✓] Prediction Market Watcher started")
    except: pass

    # Ingestion scheduler (CoinGecko, etc.)
    try:
        from cron_ingestion import start_scheduler
        result = start_scheduler()
        logger.info(f"[✓] Ingestion scheduler: {result}")
    except Exception as e:
        logger.warning(f"[✗] Ingestion scheduler: {e}")

    # Engine snapshot workers
    asyncio.create_task(_engine_snapshot_loop())
    asyncio.create_task(_engine_micro_snapshot_loop())

    # Push Intelligence
    asyncio.create_task(_push_intelligence_loop())

    # Fractal forecast scheduler
    asyncio.create_task(_fractal_forecast_scheduler())

    # Forecast scheduler
    asyncio.create_task(_forecast_scheduler())

