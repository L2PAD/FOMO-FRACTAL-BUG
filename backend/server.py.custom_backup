@app.get("/api/miniapp/billing/status")
async def miniapp_billing_status(telegram_id: str = ""):
    """Check subscription status for MiniApp user."""
    if not telegram_id:
        return JSONResponse(content={"ok": True, "plan": "FREE", "status": "active"})
    user = await db.miniapp_users.find_one({"telegram_id": telegram_id}, {"_id": 0})
    if user and user.get("plan_status") in ("pro", "PRO"):
        return JSONResponse(content={"ok": True, "plan": "PRO", "status": "active",
                                     "expiresAt": user.get("renew_date")})
    # Also check unified_users by telegram
    unified = await db.unified_users.find_one({"telegramChatId": telegram_id}, {"_id": 0})
    if unified and unified.get("plan") == "PRO":
        return JSONResponse(content={"ok": True, "plan": "PRO", "status": "active"})
    return JSONResponse(content={"ok": True, "plan": "FREE", "status": "active"})

