@app.get("/api/mobile/retention/session-hook")
async def retention_session_hook(asset: str = "BTC", request: Request = None):
    """What changed since last visit — the first thing user sees."""
    from services.ingestion import get_latest_observation
    obs = get_latest_observation(asset)
    price = obs.get("price", 0) if obs else 0

    # Get recent signals
    recent_signals = await db.signal_history.find(
        {"asset": asset}, {"_id": 0}
    ).sort("createdAt", -1).limit(3).to_list(3)

    # Build "since last visit" items
    changes = []
    if price > 0:
        changes.append({"asset": asset, "type": "price", "text": f"{asset} at ${price:,.0f}", "delta": ""})
    for sig in recent_signals[:2]:
        action = sig.get("action", "WAIT")
        conf = sig.get("confidence", 0)
        changes.append({"asset": asset, "type": "signal", "text": f"{action} signal ({conf*100:.0f}%)", "delta": ""})

    # Build expectations
    expectations = []
    expectations.append({"text": "Structure evolving — next update in ~3h", "urgency": "low"})
    if recent_signals:
        last_action = recent_signals[0].get("action", "WAIT")
        if last_action != "WAIT":
            expectations.append({"text": f"{last_action} confirmation expected soon", "urgency": "high"})
        else:
            expectations.append({"text": "Waiting for key level break", "urgency": "medium"})

    # Unfinished actions
    unfinished = []
    edges = await db.sentiment_events.find(
        {"type": {"$in": ["edge", "EDGE"]}}, {"_id": 0}
    ).sort("createdAt", -1).limit(2).to_list(2)
    if edges:
        unfinished.append({"text": f"You tracked {len(edges)} edges — 1 is close to signal", "action": "view_edge"})

    return JSONResponse(content={
        "ok": True,
        "sinceLastVisit": changes,
        "expectations": expectations,
        "unfinished": unfinished,
        "message": f"Market is moving. {len(changes)} updates since your last visit." if changes else "All quiet. Watching for setups.",
    })

