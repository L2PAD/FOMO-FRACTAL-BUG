@app.post("/api/analytics/paywall-event")
async def analytics_paywall_event(request: Request):
    """Track paywall A/B test events: view, click, conversion."""
    body = await request.json()
    event_type = body.get("event", "")  # view | click | convert
    paywall_type = body.get("type", "")  # profit | regret
    variant = body.get("variant", "A")   # A | B | C
    user_id = body.get("user_id", "")
    asset = body.get("asset", "")

    if event_type not in ("view", "click", "convert"):
        return JSONResponse(content={"ok": False, "error": "Invalid event"}, status_code=400)

    now = datetime.now(timezone.utc)
    day_key = now.strftime("%Y-%m-%d")

    await db.ab_paywall_events.insert_one({
        "event": event_type,
        "type": paywall_type,
        "variant": variant,
        "user_id": user_id,
        "asset": asset,
        "day": day_key,
        "ts": now.isoformat(),
    })

    # Increment daily counters
    await db.ab_paywall_stats.update_one(
        {"day": day_key, "type": paywall_type, "variant": variant},
        {"$inc": {event_type + "s": 1}, "$setOnInsert": {"day": day_key, "type": paywall_type, "variant": variant}},
        upsert=True,
    )

    return JSONResponse(content={"ok": True})


@app.get("/api/analytics/paywall-results")
async def analytics_paywall_results():
    """Admin: get A/B test results."""
    stats = await db.ab_paywall_stats.find({}, {"_id": 0}).sort("day", -1).to_list(100)

    # Aggregate by type+variant
    agg = {}
    for s in stats:
        key = f"{s['type']}_{s['variant']}"
        if key not in agg:
            agg[key] = {"type": s["type"], "variant": s["variant"], "views": 0, "clicks": 0, "converts": 0, "days": []}
        agg[key]["views"] += s.get("views", 0)
        agg[key]["clicks"] += s.get("clicks", 0)
        agg[key]["converts"] += s.get("converts", 0)
        agg[key]["days"].append(s["day"])

    results = []
    for k, v in agg.items():
        v["ctr"] = round(v["clicks"] / max(v["views"], 1) * 100, 1)
        v["conversion"] = round(v["converts"] / max(v["views"], 1) * 100, 1)
        v["days_count"] = len(set(v["days"]))
        del v["days"]
        results.append(v)

    return JSONResponse(content={"ok": True, "results": results, "raw": stats[:20]})

